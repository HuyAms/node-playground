{
  "annotations": { "list": [] },
  "description": "RED metrics (Rate, Errors, Duration) for microservices. Use the Job and Route dropdowns to filter by service and endpoint. Overview stats and time series for selected services/routes.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": [],
      "targetBlank": true,
      "title": "Share view (open in new tab)",
      "tooltip": "Opens this dashboard in a new tab with current Job/Route selection; bookmark or share the URL for drill-down views.",
      "type": "dashboards",
      "uid": "red-api"
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "options": { "content": "**How to use:** Select **Job** (service) and optionally **Route** (endpoint) from the dropdowns above. All panels filter by your selection. Use **All** to see every service/route. RED = Rate, Errors, Duration (proxy for user experience).", "mode": "markdown" },
      "title": "Dashboard overview",
      "type": "text"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 2 },
      "id": 0,
      "panels": [],
      "title": "Service health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "1 = healthy, 0 = down. Prometheus up metric for selected jobs.",
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto" },
          "mappings": [
            { "options": { "0": { "color": "red", "index": 0, "text": "Down" } }, "type": "value" },
            { "options": { "1": { "color": "green", "index": 0, "text": "Up" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}] }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 3 },
      "id": 9,
      "options": { "cellHeight": "sm", "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false }, "showHeader": true },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "up{job=~\"$job\"}", "format": "table", "instant": true, "refId": "A" }
      ],
      "title": "Up status (selected jobs)",
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 1,
      "panels": [],
      "title": "RED (selected services)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Request rate for selected service(s)/route(s) (5m rate).",
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" }, "thresholds": { "mode": "absolute", "steps": [{"color": "green", "value": null}] } },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 6, "x": 0, "y": 10 },
      "id": 21,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(http_requests_total{job=~\"$job\", route=~\"$route\"}[5m]))", "refId": "A" }],
      "title": "Rate (req/s)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "5xx error ratio. Red above 1%.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.01}, {"color": "red", "value": 0.05}] }
        },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 6, "x": 6, "y": 10 },
      "id": 22,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(http_requests_total{job=~\"$job\", route=~\"$route\", status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=~\"$job\", route=~\"$route\"}[5m]))", "refId": "A" }],
      "title": "Error rate (5xx)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "p99 latency.",
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" }, "thresholds": { "mode": "absolute", "steps": [{"color": "green", "value": null}] } },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 6, "x": 12, "y": 10 },
      "id": 24,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{job=~\"$job\", route=~\"$route\"}[5m])))", "refId": "A" }],
      "title": "p99 duration",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Cache hit ratio (hits / (hits + misses)) over 5m. Shown when selected job exposes cache metrics.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{"color": "green", "value": null}] }
        },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 6, "x": 18, "y": 10 },
      "id": 23,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(cache_hits_total{job=~\"$job\"}[5m])) / (sum(rate(cache_hits_total{job=~\"$job\"}[5m])) + sum(rate(cache_misses_total{job=~\"$job\"}[5m])))",
          "refId": "A"
        }
      ],
      "title": "Cache hit rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Request rate by route (top 10 by rate). Use Route dropdown to focus on specific endpoints.",
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" }, "thresholds": { "mode": "absolute", "steps": [{"color": "green", "value": null}] } },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 13 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(10, sum by (route) (job:http_requests_total:rate5m{job=~\"$job\", route=~\"$route\"}))",
          "refId": "A"
        }
      ],
      "title": "Rate by route (top 10)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "5xx / total. Red above 1%, yellow above 0.5%.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.005},
              {"color": "red", "value": 0.01}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 13 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_requests_total{job=~\"$job\", route=~\"$route\", status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=~\"$job\", route=~\"$route\"}[5m]))",
          "legendFormat": "5xx error rate",
          "refId": "A"
        }
      ],
      "title": "Error rate (5xx)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "p50, p75, p95, p99 from request duration histogram (5m rate).",
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" }, "thresholds": { "mode": "absolute", "steps": [{"color": "green", "value": null}] } },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 13 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{job=~\"$job\", route=~\"$route\"}[5m])))", "legendFormat": "p50", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.75, sum by (le) (rate(http_request_duration_seconds_bucket{job=~\"$job\", route=~\"$route\"}[5m])))", "legendFormat": "p75", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=~\"$job\", route=~\"$route\"}[5m])))", "legendFormat": "p95", "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{job=~\"$job\", route=~\"$route\"}[5m])))", "legendFormat": "p99", "refId": "D" }
      ],
      "title": "Duration (p50, p75, p95, p99)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Current number of requests in flight (concurrency).",
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" }, "thresholds": { "mode": "absolute", "steps": [{"color": "green", "value": null}] } },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 6, "x": 0, "y": 18 },
      "id": 10,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(http_requests_in_flight{job=~\"$job\"})", "refId": "A" }
      ],
      "title": "Concurrency (in-flight)",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["red", "api"],
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(http_requests_total, job)",
        "refresh": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "sort": 1,
        "current": {}
      },
      {
        "name": "route",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(http_requests_total{job=~\"$job\"}, route)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "sort": 1,
        "current": {}
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "title": "RED API Dashboard",
  "uid": "red-api",
  "version": 5,
  "weekStart": ""
}
